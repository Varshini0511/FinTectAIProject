# Copy to .env and fill in. Never commit the real .env.

# --- LLM provider (OpenAI-compatible). Default: Groq ---
# Groq key looks like gsk_...  (get one at https://console.groq.com/keys)
LLM_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1

# A model your account can access that supports tool calling.
# Groq options: llama-3.3-70b-versatile, llama-3.1-8b-instant,
#   moonshotai/kimi-k2-instruct, openai/gpt-oss-120b, qwen/qwen3-32b
FINTECH_AGENT_MODEL=llama-3.3-70b-versatile

# To use xAI Grok instead of Groq:
#   LLM_API_KEY=xai-...
#   LLM_BASE_URL=https://api.x.ai/v1
#   FINTECH_AGENT_MODEL=grok-4

# --- Postgres (account / card / transaction data) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nimbuspay

# --- LangSmith (observability) ---
# Get a key at https://smith.langchain.com -> Settings -> API Keys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=fintech-support-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # EU: https://eu.api.smith.langchain.com

# --- Eval judge model (DeepEval + LLM-as-judge) ---
# Defaults to FINTECH_AGENT_MODEL if unset.
FINTECH_JUDGE_MODEL=llama-3.3-70b-versatile
