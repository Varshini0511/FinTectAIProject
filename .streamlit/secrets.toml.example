# Streamlit Community Cloud secrets.
# On deploy: copy these keys into the app's "Secrets" box in the Streamlit Cloud
# dashboard (Manage app -> Secrets). Do NOT commit a real secrets.toml.
# Locally you don't need this file — the app reads .env instead.

LLM_API_KEY = "gsk_your_groq_key_here"
LLM_BASE_URL = "https://api.groq.com/openai/v1"
FINTECH_AGENT_MODEL = "openai/gpt-oss-120b"
FINTECH_JUDGE_MODEL = "openai/gpt-oss-120b"

# A CLOUD Postgres (Neon / Supabase) — NOT localhost. Include sslmode=require.
DATABASE_URL = "postgresql://user:password@your-host.neon.tech/nimbuspay?sslmode=require"

# Use the small spaCy model on the cloud so Presidio fits free-tier RAM.
PRESIDIO_SPACY_MODEL = "en_core_web_sm"

# Password gate for the public URL (so strangers can't burn your Groq quota).
# Leave unset locally to keep the app open on your machine.
APP_PASSWORD = "choose-a-password"

# Optional: LangSmith tracing
LANGSMITH_TRACING = "false"
# LANGSMITH_API_KEY = "lsv2_..."
